# Porta (Render/Railway injetam automaticamente — em dev usa 3001)
PORT=3001

# Conexão MongoDB (use MongoDB Atlas free tier em produção)
# Local: mongodb://localhost:27017/devspace
MONGO_URI=mongodb+srv://USER:PASS@cluster.mongodb.net/devspace?retryWrites=true&w=majority

# Segredo do JWT — em produção gere com: openssl rand -hex 64
JWT_SECRET=troque_isso_em_producao_use_um_secret_forte_de_64_chars

# URL do frontend (separe múltiplos por vírgula em prod)
# Dev:  http://localhost:5173
# Prod: https://seuapp.vercel.app,https://seuapp-preview.vercel.app
CLIENT_URL=http://localhost:5173

# Email da conta que tem acesso ao painel de moderação (banir/expulsar usuários)
# Deixe vazio para desabilitar o painel para todos.
OWNER_EMAIL=

# Token GitHub opcional — aumenta rate limit de /repos/preview
# Crie em: https://github.com/settings/tokens (escopo: public_repo)
# Sem token: 60 req/h por IP; com token: 5000 req/h
GITHUB_TOKEN=

# Cloudinary — upload de avatares e imagens do chat (25 GB free tier)
# Dashboard: https://console.cloudinary.com/ → "Product Environment Credentials"
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=

# Resend — envia o email de "esqueci minha senha" (https://resend.com)
# Crie uma conta grátis, gere uma API key. Sem domínio verificado, o Resend
# só entrega para o email da sua própria conta Resend (suficiente pra demo).
RESEND_API_KEY=
EMAIL_FROM=DevSpace <onboarding@resend.dev>

# Moderação de imagens NO SERVIDOR (detecta nudez, violência, gore, conteúdo
# perturbador). Requer ativar o add-on no painel do Cloudinary:
# Console → Add-ons → "Amazon Rekognition AI Moderation" → plano grátis.
# Depois defina o valor como: aws_rek   (vazio = sem moderação no servidor)
CLOUDINARY_MODERATION=

# GitHub OAuth — habilita o botão "Conectar GitHub" e compartilhar repos privados.
# Crie um OAuth App em: https://github.com/settings/developers
#   Authorization callback URL: <API_URL>/api/github/callback
#   ex.: https://devspace-yyl8.onrender.com/api/github/callback
GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=
# URL pública do backend (Render). Em dev pode deixar vazio (auto-detecta).
API_URL=
